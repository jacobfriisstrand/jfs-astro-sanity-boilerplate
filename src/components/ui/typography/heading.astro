---
import type { VariantProps } from "class-variance-authority";
import { cva } from "class-variance-authority";
import { cn } from "@/lib/utils";

export type Props = VariantProps<typeof headingVariants> & {
  as: "h1" | "h2" | "h3" | "h4" | "h5" | "h6";
  class?: string;
};

export const headingVariants = cva("", {
  variants: {
    size: {
      h1: "heading-1",
      h2: "heading-2",
      h3: "heading-3",
      h4: "heading-4",
      h5: "heading-5",
      h6: "heading-6",
      display: "display",
    },
    colorScheme: {
      light: "text-light",
      dark: "text-dark",
    },
  },
  defaultVariants: {
    size: "h1",
    colorScheme: "dark",
  },
});

const {
  as: Element = "h2",
  size,
  colorScheme,
  class: className,
  ...props
}: Props = Astro.props;
const variantClasses = cn(headingVariants({ size, colorScheme }));
const classes = [variantClasses, className].filter(Boolean);
---

<Element class:list={classes} {...props}>
  <slot/>
</Element>
