---
import type { VariantProps } from "class-variance-authority";
import { cva } from "class-variance-authority";
import { cn } from "@/lib/utils";

export type Props = VariantProps<typeof headingVariants> & {
  as: "h1" | "h2" | "h3" | "h4" | "h5" | "h6";
  class?: string;
};

export const headingVariants = cva("tracking-tight", {
  variants: {
    size: {
      h1: "text-5xl leading-none lg:text-6xl",
      h2: "text-3xl leading-none lg:text-4xl",
      h3: "text-xl leading-none lg:text-2xl",
      h4: "text-md leading-none lg:text-lg",
    },
    colorScheme: {
      light: "text-light",
      dark: "text-dark",
    },
  },
  defaultVariants: {
    size: "h1",
    colorScheme: "dark",
  },
});

const {
  as: Element = "h2",
  size,
  colorScheme,
  class: className,
  ...props
}: Props = Astro.props;
const variantClasses = cn(headingVariants({ size, colorScheme }));
const classes = [variantClasses, className].filter(Boolean);
---

<Element class:list={classes} {...props}>
  <slot/>
</Element>
