---
import Container from "@/components/ui/layout/container.astro";
import Heading, {
  headingVariants,
} from "@/components/ui/typography/heading.astro";
import Layout from "@/layouts/layout.astro";
---

<Layout>
  <Container size="fluid" as="div" class="py-40">
    <Container as="div">
      <Heading as="h1" class={headingVariants({ size: "h1" })}>
        Animation Variables
      </Heading>
      <p class="text-lg mb-40 mt-8">
        Testing all animation variables from the theme using Tailwind utilities
      </p>

      <div class="space-y-60">
        <!-- Duration Variables -->
        <section>
          <Heading as="h2" class={headingVariants({ size: "h2" })}>
            Duration Variables
          </Heading>
          <div
            class="mt-20 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-20"
          >
            <div class="p-20 border rounded">
              <h3 class="font-bold mb-12">duration-xs</h3>
              <p class="text-sm text-gray-600 mb-12">0.15s (150ms)</p>
              <button
                class="px-20 py-12 bg-blue-500 text-white rounded duration-xs ease-smooth hover:bg-blue-600"
              >
                Hover me
              </button>
            </div>

            <div class="p-20 border rounded">
              <h3 class="font-bold mb-12">duration-sm</h3>
              <p class="text-sm text-gray-600 mb-12">0.2s (200ms)</p>
              <button
                class="px-20 py-12 bg-blue-500 text-white rounded duration-sm ease-smooth hover:bg-blue-600"
              >
                Hover me
              </button>
            </div>

            <div class="p-20 border rounded">
              <h3 class="font-bold mb-12">duration-base</h3>
              <p class="text-sm text-gray-600 mb-12">0.25s (250ms)</p>
              <button
                class="px-20 py-12 bg-blue-500 text-white rounded duration-base ease-smooth hover:bg-blue-600"
              >
                Hover me
              </button>
            </div>

            <div class="p-20 border rounded">
              <h3 class="font-bold mb-12">duration-lg</h3>
              <p class="text-sm text-gray-600 mb-12">0.3s (300ms)</p>
              <button
                class="px-20 py-12 bg-blue-500 text-white rounded duration-lg ease-smooth hover:bg-blue-600"
              >
                Hover me
              </button>
            </div>

            <div class="p-20 border rounded">
              <h3 class="font-bold mb-12">duration-xl</h3>
              <p class="text-sm text-gray-600 mb-12">0.4s (400ms)</p>
              <button
                class="px-20 py-12 bg-blue-500 text-white rounded duration-xl ease-smooth hover:bg-blue-600"
              >
                Hover me
              </button>
            </div>
          </div>
        </section>

        <!-- Easing Variables -->
        <section>
          <Heading as="h2" class={headingVariants({ size: "h2" })}>
            Easing Variables
          </Heading>
          <div class="mt-20 grid grid-cols-1 md:grid-cols-2 gap-20">
            <div class="p-20 border rounded">
              <h3 class="font-bold mb-12">ease-smooth</h3>
              <p class="text-sm text-gray-600 mb-12">
                cubic-bezier(0.625, 0.05, 0, 1)
              </p>
              <button
                class="px-20 py-12 bg-green-500 text-white rounded duration-base ease-smooth hover:bg-green-600"
              >
                Hover me
              </button>
            </div>

            <div class="p-20 border rounded">
              <h3 class="font-bold mb-12">ease-bounce</h3>
              <p class="text-sm text-gray-600 mb-12">linear bounce curve</p>
              <button
                class="px-20 py-12 bg-purple-500 text-white rounded duration-base ease-bounce hover:bg-purple-600"
              >
                Hover me
              </button>
            </div>
          </div>
        </section>
      </div>
    </Container>
  </Container>
</Layout>

<style>
  button {
    transition-property: background-color, transform;
  }

  button:hover {
    transform: scale(1.05);
  }
</style>
