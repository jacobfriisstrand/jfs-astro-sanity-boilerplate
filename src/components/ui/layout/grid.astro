---
import type { HTMLTag } from "astro/types";

export type Props = {
  as: HTMLTag;
  class?: string;
};

const { as: Element = "div", class: className, ...props }: Props = Astro.props;
const baseClasses =
  "component-grid grid grid-cols-4 lg:grid-cols-12 desktop:gap-12 gap-8 lg:gap-24";
const classes = [baseClasses, className].filter(Boolean);
---

<Element class:list={classes} {...props}>
  <slot/>
</Element>
