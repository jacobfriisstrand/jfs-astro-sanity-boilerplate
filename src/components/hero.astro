---
import type { Hero } from "sanity.types";
import Media from "@/components/media.astro";
import Heading from "@/components/ui/typography/heading.astro";

/**
 * Props type derived from auto-generated Sanity types
 * The _key field is added when components are used in arrays
 */
type Props = Hero & { _key: string };

const { title, media } = Astro.props;
---

<section class="hero">
  <Heading as="h1" size="h1">{title}</Heading>
  {media && <Media media={media} loading="eager" aspectRatio="3/4" class="max-h-[80svh] w-1/2"/>}
</section>
