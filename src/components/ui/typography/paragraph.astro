---
import type { VariantProps } from "class-variance-authority";
import { cva } from "class-variance-authority";
import { cn } from "@/lib/utils";

export type Props = VariantProps<typeof paragraphVariants> & {
  as: "p" | "span" | "small";
  class?: string;
};

export const paragraphVariants = cva("text-balance leading-24", {
  variants: {
    size: {
      default: "text-xs lg:text-sm",
    },
    colorScheme: {
      light: "text-light",
      dark: "text-dark",
    },
  },
  defaultVariants: {
    size: "default",
    colorScheme: "dark",
  },
});

const {
  as: Element = "p",
  size,
  colorScheme,
  class: className,
  ...props
}: Props = Astro.props;
const variantClasses = cn(paragraphVariants({ size, colorScheme }));
const classes = [variantClasses, className].filter(Boolean);
---

<Element class:list={classes} {...props}>
  <slot/>
</Element>
