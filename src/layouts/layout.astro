---
import "@/styles/global.css";
import { Font } from "astro:assets";
import { ClientRouter, fade } from "astro:transitions";
import { VisualEditing } from "@sanity/astro/visual-editing";
import type { SanityDocument } from "@sanity/client";
import { stegaClean } from "@sanity/client/stega";
import type { WebSite, WithContext } from "schema-dts";
import Footer from "@/components/core/footer.astro";
import Metadata from "@/components/core/metadata.astro";
import Navigation from "@/components/core/navigation.astro";
import { serializeJsonLd } from "@/lib/jsonld";
import { loadFooter } from "@/sanity/lib/load-footer";
import { loadNavigation } from "@/sanity/lib/load-navigation";
import { loadSiteSettings } from "@/sanity/lib/load-site-settings";

type Props = {
  page: SanityDocument;
  title: string;
  description: string;
  image: string;
  imageAlt?: string;
  noIndex: boolean;
};

const { isPreview } = Astro.locals;

const { title, description, image, imageAlt, noIndex } = Astro.props;

const [navigation, footerData, siteSettings] = await Promise.all([
  loadNavigation(isPreview),
  loadFooter(isPreview),
  loadSiteSettings(isPreview),
]);

const siteUrl = Astro.site ? new URL("/", Astro.site) : new URL("/", Astro.url);

const websiteJsonLd: WithContext<WebSite> = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${siteUrl}#website`,
  name: siteSettings?.title ? stegaClean(siteSettings.title) : "",
  description: siteSettings?.description
    ? stegaClean(siteSettings.description)
    : "",
  url: siteUrl.toString(),
};

// Resolve favicon from Sanity site settings
const settingsData = siteSettings as Record<string, unknown> | null;
const faviconAsset = (settingsData?.favicon as Record<string, unknown>)
  ?.asset as
  | { url?: string; mimeType?: string; extension?: string }
  | undefined;
const faviconUrl = faviconAsset?.url;
const faviconExtension = faviconAsset?.extension;
const faviconMimeType = faviconAsset?.mimeType;
const isSvgFavicon =
  faviconExtension === "svg" || faviconMimeType === "image/svg+xml";
---

<html lang="en">
  <head>
    <meta charset="utf-8">
    {faviconUrl ? (
      isSvgFavicon ? (
        <link rel="icon" type="image/svg+xml" href={faviconUrl}>
      ) : (
        <>
          <link rel="icon" type={faviconMimeType || "image/png"} sizes="32x32" href={`${faviconUrl}?w=32&h=32&fit=crop`}>
          <link rel="icon" type={faviconMimeType || "image/png"} sizes="16x16" href={`${faviconUrl}?w=16&h=16&fit=crop`}>
        </>
      )
    ) : (
      <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    )}
    {faviconUrl && !isSvgFavicon && (
      <link rel="apple-touch-icon" sizes="180x180" href={`${faviconUrl}?w=180&h=180&fit=crop`}>
    )}
    <link rel="sitemap" href="/sitemap-index.xml">
    <ClientRouter/>
    <Font cssVariable="--font-satoshi"/>
    <meta name="viewport" content="width=device-width">
    <meta name="generator" content={Astro.generator}>
    <Metadata
      title={title}
      description={description}
      image={image}
      imageAlt={imageAlt}
      noIndex={noIndex}
    />
    <script
      type="application/ld+json"
      set:html={serializeJsonLd(websiteJsonLd)}
    />
  </head>
  <body
    class="bg-background text-foreground text-balance antialiased grid grid-rows-[auto_1fr_auto] min-h-dvh"
    data-astro-preview={isPreview ? "true" : "false"}
  >
    <Navigation navigation={navigation}/>
    <main transition:animate={fade({ duration: "0.3s" })}>
      <slot/>
    </main>
    <Footer footerData={footerData}/>
    <VisualEditing enabled={isPreview}/>
  </body>
</html>
