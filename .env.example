# Sanity CMS Configuration
PUBLIC_SANITY_PROJECT_ID=your-project-id
PUBLIC_SANITY_DATASET=development
SANITY_API_READ_TOKEN=your-read-token
PUBLIC_SANITY_VISUAL_EDITING_ENABLED=false

# Bunny CDN - Storage (for images)
BUNNY_STORAGE_API_KEY=your-storage-api-key
BUNNY_STORAGE_REGION=
BUNNY_PULL_ZONE_NAME=your-pull-zone-name.b-cdn.net
PUBLIC_BUNNY_CDN_HOSTNAME=your-cdn-hostname.b-cdn.net

# Bunny CDN - Stream (for videos)
BUNNY_LIBRARY_ID=your-library-id
BUNNY_API_KEY=your-stream-api-key